{
	"name": "wpboilerplate/acrossai-core-abilities",
	"type": "wordpress-plugin",
	"license": "GPL-2.0-or-later",
	"description": "Composer to autoload the condition checking for which this add-on is made",
	"homepage": "https://github.com/WPBoilerplate/",
	"minimum-stability": "dev",
	"require": {
		"php": ">=7.4",
		"automattic/jetpack-autoloader": "^5.0",
		"wpboilerplate/wpb-updater-checker-github": "dev-main"
	},
	"keywords": [
		"wordpress",
		"plugin"
	],
	"support": {
		"issues": "https://github.com/wpboilerplate/acrossai-core-abilities/issues"
	},
	"authors": [
		{
			"name": "WPBoilerplate"
		}
	],
	"autoload": {
		"psr-4": {
			"Acrossai_Core_Abilities\\Includes\\": "includes/",
			"Acrossai_Core_Abilities\\Admin\\": "admin/",
			"Acrossai_Core_Abilities\\Public\\": "public/"
		}
	},
	"require-dev": {
		"wp-coding-standards/wpcs": "*",
		"dealerdirect/phpcodesniffer-composer-installer": "^1.2",
		"phpunit/phpunit": "^13.2@dev"
	},
	"config": {
		"allow-plugins": {
			"dealerdirect/phpcodesniffer-composer-installer": true,
			"automattic/jetpack-autoloader": true
		}
	}
}
